import os
import google.generativeai as genai
from dotenv import load_dotenv

load_dotenv()

API_KEY = os.getenv("GEMINI_API_KEY")
if not API_KEY:
    raise ValueError("Missing GEMINI_API_KEY. Add it to your .env file (GEMINI_API_KEY=...).")

genai.configure(api_key=API_KEY)

def generate_story(topic: str) -> str:
    model = genai.GenerativeModel("gemini-1.5-flash")
    prompt = (
        f"Write a 30-second philosophical story about {topic} for a faceless reel.\n"
        "Structure:\n"
        "1) Hook (1 sentence)\n"
        "2) Story (3-5 sentences)\n"
        "3) Deep insight (1 sentence)\n"
        "4) Visual description (2-3 shots)\n"
        "Keep it punchy and concrete."
    )

    try:
        response = model.generate_content(prompt)
        return response.text.strip()
    except Exception as e:
        return f"Error generating story: {e}"

if __name__ == "__main__":
    print(generate_story("Stoicism and inner peace"))
